# Copy this file to .env and set DATA_DIR to your asset storage location.
# .env is gitignored — it stays on your machine only.

# Where your 3D assets live on the HOST machine.
# The container maps this directory to /data internally.
#
# Examples:
#   External drive:    DATA_DIR=/Volumes/MyDrive/pointcloud-data
#   Home folder:       DATA_DIR=/Users/yourname/pointcloud-data
#   Next to this file: DATA_DIR=./data   (default if not set)

DATA_DIR=./data
